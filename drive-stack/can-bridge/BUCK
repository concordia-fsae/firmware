load("//tools/yamcan/defs.bzl", "generate_c_library", "generate_resources", "generate_rust_library")
load("//drive-stack/carputer:defs.bzl", "carputer_application_target")

export_file(
    name = "CANIO_componentSpecific.h",
    src = "include/CANIO_componentSpecific.h",
    visibility = ["PUBLIC"],
)

export_file(
    name = "YamcanConfig.h",
    src = "include/YamcanConfig.h",
    visibility = ["PUBLIC"],
)

generate_resources(
    name = "yamcan-carputer-veh-codegen",
    network_dep = "//network:network",
    node = "carputerVeh",
    rust_wrapper = True,
    visibility = ["PUBLIC"],
)

generate_c_library(
    name = "yamcan-carputer-veh",
    codegen_target = ":yamcan-carputer-veh-codegen",
    extra_srcs = [
        "//components/shared/code:libs/Utility.c",
    ],
    extra_exported_headers = {
        "CANIO_componentSpecific.h": "include/CANIO_componentSpecific.h",
        "YamcanConfig.h": "include/YamcanConfig.h",
    },
    library_deps = [
        "//components/shared/code:headers",
    ],
    visibility = ["PUBLIC"],
    target_compatible_with = [
        "prelude//os/constraints:linux",
    ],
)

generate_rust_library(
    name = "yamcan-carputer-veh-rust",
    crate = "yamcan_generated",
    codegen_target = ":yamcan-carputer-veh-codegen",
    c_dep = ":yamcan-carputer-veh",
    target_compatible_with = [
        "prelude//os/constraints:linux",
    ],
    visibility = ["PUBLIC"],
)

rust_library(
    name = "lib-veh",
    crate = "can_bridge",
    srcs = glob(["src/**/*.rs"], exclude=["main_*.rs"]),
    edition = "2024",
    deps = [
        ":yamcan-carputer-veh-rust",
        "//third_party:chrono",
        "//third_party:clap",
        "//third_party:flate2",
        "//third_party:libc",
        "//third_party:socketcan",
        "//third_party:serde_json",
        "//third_party:tar",
    ],
    target_compatible_with = [
        "prelude//os/constraints:linux",
    ],
    visibility = ["PUBLIC"],
)

rust_binary(
    name = "can-bridge-veh",
    srcs = ["src/main_veh.rs"],
    crate_root = "src/main_veh.rs",
    edition = "2024",
    deps = [
        ":lib-veh",
    ],
    target_compatible_with = [
        "prelude//os/constraints:linux",
    ],
    visibility = ["PUBLIC"],
)

configured_alias(
    name = "bin-veh-arm64",
    actual = ":can-bridge-veh",
    platform = "//buck2/platforms:arm64-linux",
    visibility = ["PUBLIC"],
)

