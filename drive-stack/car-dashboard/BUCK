    ],
    extra_exported_headers = {
        "CANIO_componentSpecific.h": "//drive-stack/can-bridge:CANIO_componentSpecific.h",
        "YamcanConfig.h": "//drive-stack/can-bridge:YamcanConfig.h",
    },
    library_deps = [
        "//components/shared/code:headers",
    ],
    visibility = ["PUBLIC"],
    target_compatible_with = [
        "prelude//os/constraints:linux",
    ],
)

