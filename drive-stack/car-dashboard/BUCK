    name = "bin-arm64",
    actual = ":dashboard",
    platform = "//buck2/platforms:arm64-linux",
    visibility = ["PUBLIC"],
)

carputer_application_target(
    name = "carputer",
    target_node = "dashboard",
    binary = ":bin-arm64",
    binary_install_name = "dashboard",
    service_src = "dashboard.service",
    service_install_name = "dashboard.service",
    resource_deps = {
        "application/config/ota-agent/uds-manifest.yaml": "//network:manifest-uds",
    },
    include_artifact_hash = False,
)

native.command_alias(
    name = "run",
    exe = ":dashboard",
    args = [
        "--uds-manifest",
        "$(location //network:manifest-uds)",
        "--veh-iface",
        "vcanVeh",
