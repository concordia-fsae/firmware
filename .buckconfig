[cells]
  root = .
  prelude = prelude
  toolchains = buck2/toolchains
  none = none

[cell_aliases]
  config = prelude
  ovr_config = prelude
  fbcode = none
  fbsource = none
  fbcode_macros = none
  buck2 = none

# Use Buck's bundled prelude.
[external_cells]
  prelude = bundled

[parser]
  target_platform_detector_spec = target:root//...->prelude//platforms:default

[build]
  execution_platforms = prelude//platforms:default
